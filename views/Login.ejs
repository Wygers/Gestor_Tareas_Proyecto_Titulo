<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Gestor de Tareas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background: #f0f2f5;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: Arial, sans-serif;
        }
        .login-wrapper {
            width: 100%;
            max-width: 1050px;
            background: white;
            border-radius: 22px;
            overflow: hidden;
            box-shadow: 0 10px 35px rgba(0,0,0,0.12);
        }
        .login-left {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            color: white;
            padding: 50px;
            min-height: 560px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .login-left .icon-main {
            font-size: 4rem;
            margin-bottom: 20px;
        }
        .login-left h1 {
            font-weight: 800;
            margin-bottom: 18px;
        }
        .login-left p {
            opacity: 0.9;
            font-size: 1.05rem;
        }
        .feature-item {
            display: flex;
            align-items: center;
            margin-top: 18px;
            font-weight: 500;
        }
        .feature-item i {
            width: 36px;
            height: 36px;
            background: rgba(255,255,255,0.15);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-right: 12px;
        }
        .login-right {
            padding: 50px;
            min-height: 560px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .form-control {
            border-radius: 12px;
            padding: 12px 15px;
        }
        .input-group-text {
            border-radius: 12px 0 0 12px;
            background: #f8f9fa;
        }
        .btn-login {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 12px;
            padding: 13px;
            font-weight: 700;
            color: white;
            transition: all 0.3s ease;
        }
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 22px rgba(102,126,234,0.35);
            color: white;
        }
        .login-badge {
            background: #eef2ff;
            color: #2a5298;
            border-radius: 50px;
            padding: 8px 15px;
            font-size: 0.85rem;
            font-weight: 700;
            display: inline-block;
            margin-bottom: 20px;
        }
        .small-link {
            color: #2a5298;
            text-decoration: none;
            font-weight: 600;
        }
        .small-link:hover {
            text-decoration: underline;
        }
        @media (max-width: 768px) {
            .login-left {
                min-height: auto;
                padding: 35px;
            }
            .login-right {
                min-height: auto;
                padding: 35px;
            }
        }
    </style>
</head>
<body>
<div class="container px-3">
    <div class="login-wrapper">
        <div class="row g-0">
            <div class="col-lg-6 login-left">
                <div>
                    <i class="bi bi-kanban-fill icon-main"></i>
                    <h1>Gestor de Tareas Profesional</h1>
                    <p>
                        Plataforma web orientada a la gestión, ejecución y trazabilidad
                        de tareas operativas en tiempo real.
                    </p>
                    <div class="feature-item">
                        <i class="bi bi-check2-square"></i>
                        <span>Control de tareas y órdenes de trabajo</span>
                    </div>
                    <div class="feature-item">
                        <i class="bi bi-shield-check"></i>
                        <span>Acceso seguro según tipo de usuario</span>
                    </div>
                    <div class="feature-item">
                        <i class="bi bi-graph-up-arrow"></i>
                        <span>Seguimiento operativo y toma de decisiones</span>
                    </div>
                    <div class="feature-item">
                        <i class="bi bi-clock-history"></i>
                        <span>Trazabilidad y control auditable</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 login-right">
                <div>
                    <span class="login-badge">
                        <i class="bi bi-lock-fill me-1"></i> Acceso al sistema
                    </span>
                    <h2 class="fw-bold mb-2">Iniciar sesión</h2>
                    <p class="text-muted mb-4">
                        Ingresa tus credenciales para acceder al panel de control.
                    </p>
                    <% if (error) { %>
                        <div class="alert alert-danger d-flex align-items-center" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <div><%= error %></div>
                        </div>
                    <% } %>
                    <form action="/auth/login" method="POST">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Correo electrónico</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-envelope"></i>
                                </span>
                                <input 
                                    type="email" 
                                    name="correo" 
                                    class="form-control" 
                                    placeholder="ejemplo@empresa.cl"
                                    required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Contraseña</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-key"></i>
                                </span>
                                <input 
                                    type="password" 
                                    name="contrasena" 
                                    class="form-control" 
                                    placeholder="Ingresa tu contraseña"
                                    required>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="recordar">
                                <label class="form-check-label small" for="recordar">
                                    Recordarme
                                </label>
                            </div>
                            <a href="#" class="small-link small">¿Olvidaste tu contraseña?</a>
                        </div>
                        <button type="submit" class="btn btn-login w-100">
                            <i class="bi bi-box-arrow-in-right me-2"></i>
                            Ingresar al sistema
                        </button>
                    </form>
                    <div class="text-center mt-4 text-muted small">
                        © 2026 Gestor de Tareas Profesional
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>